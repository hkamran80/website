---
import "../styles/global.css";
import Head from "../components/Head.astro";
import NavigationBar from "../components/NavigationBar.astro";
import Footer from "../components/Footer.astro";
import Feeds from "../components/Feeds.astro";

type RobotDirective = "noindex";

type Props = {
    title?: string;
    robotDirective?: RobotDirective;
};

const { title: providedTitle, robotDirective } = Astro.props;

const title = providedTitle ? providedTitle + " | H. Kamran" : "H. Kamran";
// This statement will go into effect upon PR merge
const robots =
    "noai, noimageai, noml" + (robotDirective ? ", " + robotDirective : "");
---

<!doctype html>
<html lang="en" class="text-c-normal">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="sitemap" href="/sitemap-index.xml" />

        <Feeds feed="all" />
        <Feeds feed="articles" />
        <Feeds feed="notes" />

        <meta name="robots" content="noai, noimageai, noml, noindex" />
        <meta name="fediverse:creator" content="@hkamran@vmst.io" />

        <meta property="og:locale" content="en_US" />
        <meta property="og:site_name" content="H. Kamran" />

        <title>
            {title}
        </title>

        <Head />

        <slot name="structured-data" />
    </head>
    <body>
        <NavigationBar />
        <slot />
        <Footer />
    </body>
</html>

<style is:global>
    /* Improve page speed */
    /* https://css-tricks.com/almanac/properties/c/content-visibility/ */
    img {
        content-visibility: auto;
    }
</style>
