---
import Layout from "../../layouts/Layout.astro";
import PostStructuredData from "../../components/PostStructuredData.astro";
import Container from "../../components/container.astro";
import PageHeader from "../../components/PageHeader.astro";
import Link from "../../components/Link.astro";
import { Image } from "astro:assets";
import { getCollection, render } from "astro:content";
import { slugify } from "@hkamran/utility-strings";

export const getStaticPaths = async () => {
    const posts = await getCollection(
        "posts",
        ({ data }) => data.type === "article",
    );
    return posts.map((post) => ({
        params: { id: post.id },
        props: { post },
    }));
};

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout>
    <PostStructuredData slot="structured-data" post={post} />
    <Container>
        <main class="place-items-center pt-2 pb-8 md:pt-8">
            <PageHeader
                title={post.data.title}
                subtitle={post.data.description}
            >
                <Fragment slot="description">
                    {
                        post.data.published && post.data.updated && (
                            <time>
                                {new Intl.DateTimeFormat("en", {
                                    year: "numeric",
                                    month: "long",
                                    day: "numeric",
                                }).formatRange(
                                    post.data.published,
                                    post.data.updated,
                                )}
                            </time>
                        )
                    }

                    {
                        post.data.published ? (
                            <time
                                datetime={post.data.published.toISOString()}
                                class={`dt-published published ${post.data.updated && "hidden"}`}
                            >
                                {post.data.published.toLocaleDateString(
                                    undefined,
                                    {
                                        year: "numeric",
                                        month: "long",
                                        day: "numeric",
                                    },
                                )}
                            </time>
                        ) : (
                            "Unpublished"
                        )
                    }

                    {
                        post.data.updated && (
                            <time
                                datetime={post.data.updated.toISOString()}
                                class="dt-updated updated hidden"
                            >
                                {post.data.updated.toLocaleDateString(
                                    undefined,
                                    {
                                        year: "numeric",
                                        month: "long",
                                        day: "numeric",
                                    },
                                )}
                            </time>
                        )
                    }

                    &bull;

                    {
                        post.data.tags.map((tag, index) => (
                            <Fragment>
                                <Link
                                    href={`/tags/${slugify(tag)}`}
                                    class="text-pink-700 transition-colors duration-300 hover:text-pink-600"
                                >
                                    {tag}
                                </Link>
                                {index !== post.data.tags.length - 1
                                    ? ", "
                                    : ""}
                            </Fragment>
                        ))
                    }
                </Fragment>
            </PageHeader>

            {
                post.data.published && (
                    <Image
                        src={post.data.img!.src}
                        alt={post.data.img!.alt}
                        width={2000}
                        height={1000}
                        class="rounded-md max-w-3xl mx-auto mt-6"
                        priority
                    />
                )
            }

            <article
                class="prose dark:prose-invert mt-6 max-w-3xl mx-auto prose-a:text-pink-600"
            >
                <Content />
            </article>
        </main>
    </Container>
</Layout>
