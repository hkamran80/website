---
import { getEntry } from "astro:content";
import UtilityLayout from "../../layouts/UtilityLayout.astro";

const utility = await getEntry(
    "utilities",
    "overall-grade-after-final-calculator",
);
---

<UtilityLayout utility={utility}>
    <section class="grid grid-cols-1 gap-4 md:grid-cols-2">
        <div class="grid gap-3">
            <label
                for="grade-before-final"
                class="peer-disabled:cursor -not-allowed flex items-center gap-2 text-sm leading-none font-medium select-none group-data-[disabled=true]:pointer-events-none group-data-[disabled=true]:opacity-50 peer-disabled:opacity-50"
            >
                Grade Before Final
            </label>
            <input
                id="grade-before-final"
                type="number"
                class="placeholder:text-muted-foreground selection:bg-primary selection:text-primary-foreground dark:bg-input/30 border-input focus-visible:border-ring aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40 aria-invalid:border-destructive flex h-9 w-full min-w-0 rounded-md bg-neutral-100 px-3 py-1 text-base shadow-xs transition-[color,box-shadow] outline-none focus-visible:ring-[3px] focus-visible:ring-pink-400/50 focus-visible:ring-pink-700/50 disabled:pointer-events-none disabled:cursor-not-allowed disabled:opacity-50 md:text-sm dark:bg-neutral-900"
                placeholder="Grade before final"
            />
        </div>

        <div class="grid gap-3">
            <label
                for="final-score"
                class="peer-disabled:cursor -not-allowed flex items-center gap-2 text-sm leading-none font-medium select-none group-data-[disabled=true]:pointer-events-none group-data-[disabled=true]:opacity-50 peer-disabled:opacity-50"
            >
                Final Score
            </label>
            <input
                id="final-score"
                type="number"
                class="placeholder:text-muted-foreground selection:bg-primary selection:text-primary-foreground dark:bg-input/30 border-input focus-visible:border-ring aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40 aria-invalid:border-destructive flex h-9 w-full min-w-0 rounded-md bg-neutral-100 px-3 py-1 text-base shadow-xs transition-[color,box-shadow] outline-none focus-visible:ring-[3px] focus-visible:ring-pink-400/50 focus-visible:ring-pink-700/50 disabled:pointer-events-none disabled:cursor-not-allowed disabled:opacity-50 md:text-sm dark:bg-neutral-900"
                placeholder="Score"
            />
        </div>
    </section>

    <section class="mt-4 grid gap-3">
        <label
            for="final-weight"
            class="peer-disabled:cursor -not-allowed flex items-center gap-2 text-sm leading-none font-medium select-none group-data-[disabled=true]:pointer-events-none group-data-[disabled=true]:opacity-50 peer-disabled:opacity-50"
        >
            Final Weight
        </label>
        <input
            id="final-weight"
            type="number"
            class="placeholder:text-muted-foreground selection:bg-primary selection:text-primary-foreground dark:bg-input/30 border-input focus-visible:border-ring aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40 aria-invalid:border-destructive flex h-9 w-full min-w-0 rounded-md bg-neutral-100 px-3 py-1 text-base shadow-xs transition-[color,box-shadow] outline-none focus-visible:ring-[3px] focus-visible:ring-pink-400/50 focus-visible:ring-pink-700/50 disabled:pointer-events-none disabled:cursor-not-allowed disabled:opacity-50 md:text-sm dark:bg-neutral-900"
            placeholder="Weight"
        />
    </section>

    <hr />

    <section class="mt-4 grid gap-3">
        <label
            for="grade-after-final"
            class="peer-disabled:cursor -not-allowed flex items-center gap-2 text-sm leading-none font-medium select-none group-data-[disabled=true]:pointer-events-none group-data-[disabled=true]:opacity-50 peer-disabled:opacity-50"
        >
            Grade After Final
        </label>
        <input
            id="grade-after-final"
            type="number"
            class="placeholder:text-muted-foreground selection:bg-primary selection:text-primary-foreground dark:bg-input/30 border-input focus-visible:border-ring aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40 aria-invalid:border-destructive flex h-9 w-full min-w-0 rounded-md bg-neutral-100 px-3 py-1 text-base shadow-xs transition-[color,box-shadow] outline-none focus-visible:ring-[3px] focus-visible:ring-pink-400/50 focus-visible:ring-pink-700/50 disabled:pointer-events-none disabled:cursor-not-allowed disabled:opacity-50 md:text-sm dark:bg-neutral-900"
            placeholder="Grade after final"
            readonly
        />
    </section>
</UtilityLayout>

<script>
    const gradeBeforeFinalElement =
            document.getElementById("grade-before-final"),
        finalScoreElement = document.getElementById("final-score"),
        finalWeightElement = document.getElementById("final-weight"),
        gradeAfterFinalElement = document.getElementById("grade-after-final");

    const computeScore = () => {
        const gradeBeforeFinal = Number(gradeBeforeFinalElement?.value),
            finalScore = Number(finalScoreElement?.value),
            finalWeight = Number(finalWeightElement?.value);

        if (gradeBeforeFinal && finalScore && finalWeight) {
            const finalWeightDecimal = finalWeight / 100;
            const score =
                ((1 - finalWeightDecimal) * (gradeBeforeFinal / 100) +
                    finalWeightDecimal * (finalScore / 100)) *
                100;

            gradeAfterFinalElement!.value = score.toFixed(2);
        }
    };

    gradeBeforeFinalElement?.addEventListener("keyup", computeScore);
    finalScoreElement?.addEventListener("keyup", computeScore);
    finalWeightElement?.addEventListener("keyup", computeScore);
</script>
