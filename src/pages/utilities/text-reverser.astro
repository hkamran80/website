---
import { getEntry } from "astro:content";
import UtilityLayout from "../../layouts/UtilityLayout.astro";

const utility = await getEntry("utilities", "text-reverser");
---

<UtilityLayout utility={utility}>
    <section class="mt-4 grid gap-3">
        <label
            for="text"
            class="peer-disabled:cursor -not-allowed flex items-center gap-2 text-sm leading-none font-medium select-none group-data-[disabled=true]:pointer-events-none group-data-[disabled=true]:opacity-50 peer-disabled:opacity-50"
        >
            Text
        </label>
        <input
            id="text"
            type="text"
            class="placeholder:text-muted-foreground selection:bg-primary selection:text-primary-foreground dark:bg-input/30 border-input focus-visible:border-ring aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40 aria-invalid:border-destructive flex h-9 w-full min-w-0 rounded-md bg-neutral-100 px-3 py-1 text-base shadow-xs transition-[color,box-shadow] outline-none focus-visible:ring-[3px] focus-visible:ring-pink-400/50 focus-visible:ring-pink-700/50 disabled:pointer-events-none disabled:cursor-not-allowed disabled:opacity-50 md:text-sm dark:bg-neutral-900"
            placeholder="Text"
        />
    </section>

    <hr />

    <section class="mt-4 grid gap-3">
        <label
            for="reversed"
            class="peer-disabled:cursor -not-allowed flex items-center gap-2 text-sm leading-none font-medium select-none group-data-[disabled=true]:pointer-events-none group-data-[disabled=true]:opacity-50 peer-disabled:opacity-50"
        >
            Reversed Text
        </label>
        <input
            id="reversed"
            type="text"
            class="placeholder:text-muted-foreground selection:bg-primary selection:text-primary-foreground dark:bg-input/30 border-input focus-visible:border-ring aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40 aria-invalid:border-destructive flex h-9 w-full min-w-0 rounded-md bg-neutral-100 px-3 py-1 text-base shadow-xs transition-[color,box-shadow] outline-none focus-visible:ring-[3px] focus-visible:ring-pink-400/50 focus-visible:ring-pink-700/50 disabled:pointer-events-none disabled:cursor-not-allowed disabled:opacity-50 md:text-sm dark:bg-neutral-900"
            placeholder="txeT"
            readonly
        />
    </section>
</UtilityLayout>

<script>
    const textElement = document.getElementById("text"),
        reversedElement = document.getElementById("reversed");

    const reverse = () => {
        const text = textElement?.value;
        reversedElement!.value = text.split("").reverse().join("");
    };

    textElement?.addEventListener("keyup", reverse);
</script>
