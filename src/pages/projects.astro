---
import Layout from "../layouts/Layout.astro";
import Container from "../components/container.astro";
import PageHeader from "../components/PageHeader.astro";
import ShowcaseItem from "../components/ShowcaseItem.astro";
import { getCollection } from "astro:content";

const showcase = (await getCollection("showcase")).sort((a, b) =>
    a.data.name.localeCompare(b.data.name),
);
---

<Layout title="Projects">
    <Container width="narrow">
        <PageHeader title="Projects" />

        <section class="mt-8">
            <h2
                class="text-2xl font-semibold lg:tracking-tight xl:tracking-tighter"
            >
                Featured
            </h2>
            <ul class="gap-4">
                {
                    showcase
                        .filter((item) => item.data.featured)
                        .map((item) => <ShowcaseItem item={item} />)
                }
            </ul>
        </section>

        <hr class="my-6" />

        <section>
            <h2
                class="text-2xl font-semibold lg:tracking-tight xl:tracking-tighter"
            >
                All
            </h2>

            <ul class="gap-4">
                {showcase.map((item) => <ShowcaseItem item={item} />)}
            </ul>
        </section>
    </Container>
</Layout>
