---
import Layout from "../layouts/Layout.astro";
import Container from "../components/container.astro";
import PageHeader from "../components/PageHeader.astro";
import Link from "../components/Link.astro";
import TOC from "../components/TOC.astro";
import { getCollection } from "astro:content";
import type { MarkdownHeading } from "astro";

const blogroll = await getCollection("blogroll");
const headings: MarkdownHeading[] = blogroll.map(({ id }) => ({
    depth: 2,
    slug: id.toLowerCase(),
    text: id,
}));
---

<Layout title="Blogroll">
    <Container>
        <main class="place-items-center pt-2 pb-8 md:pt-8">
            <PageHeader title="Blogroll" class="mx-auto max-w-3xl">
                <Fragment slot="description">
                    Download <Link
                        href="/blogroll.opml"
                        class="text-pink-600 underline">the OPML file</Link
                    > and import them all into your feed reader of choice.
                </Fragment>
            </PageHeader>

            <TOC headings={headings} />

            <article
                class="mx-auto prose mt-6 max-w-3xl dark:prose-invert prose-a:text-pink-600"
            >
                {
                    blogroll.map((category) => (
                        <section>
                            <h2 id={category.id.toLowerCase()}>
                                {category.id}
                            </h2>
                            <table>
                                <thead>
                                    <tr>
                                        <th>{category.id.slice(0, -1)}</th>
                                        <th>Feed</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {category.data.entries.map((entry) => (
                                        <tr>
                                            <td>
                                                <a href={entry.url}>
                                                    {entry.name}
                                                </a>
                                            </td>
                                            <td>
                                                <a href={entry.feedUrl}>
                                                    Subscribe
                                                </a>
                                            </td>
                                        </tr>
                                    ))}
                                </tbody>
                            </table>
                        </section>
                    ))
                }

                <p class="text-sm">
                    The OPML was generated by <Link href="/self-hosted"
                        >FreshRSS</Link
                    > and includes <Link
                        href="https://freshrss.github.io/FreshRSS/en/developers/OPML.html#freshrss-opml-extension"
                        >some FreshRSS-specific tags</Link
                    > such as full-text selection and filtering.
                </p>
            </article>
        </main>
    </Container>
</Layout>

<style>
    tr th:first-child,
    tr td:first-child {
        width: 75%;
    }
</style>
