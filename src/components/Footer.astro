---
const links = [
    ["Projects", "Articles", "Notes", "Programs"],
    ["My Setup", "Support", "LLM Policy", "License", "Privacy Policy"],
];
---

<footer
    class="mb-10 flex flex-col lg:flex-row justify-between text-xs text-gray-500 max-w-(--breakpoint-xl) mx-auto px-5"
>
    <section class="max-w-lg gap-1 flex-1 w-full">
        <p>
            Copyright &copy; {new Date().getFullYear()} H. Kamran. All rights reserved.
        </p>
        <p>
            This site is designed and made exclusively by humans.<wbr /> No "AI"
            was used in the making of any of the content on this site.
        </p>
    </section>

    <section class="text-right">
        {
            links.map((linkGroup) => (
                <ul class="flex flex-row gap-2 mb-1">
                    {linkGroup.map((link) => (
                        <li>
                            <a
                                href="#"
                                class="text-gray-500 hover:text-gray-900 dark:hover:text-gray-100"
                            >
                                {link}
                            </a>
                        </li>
                    ))}
                </ul>
            ))
        }
    </section>
</footer>
