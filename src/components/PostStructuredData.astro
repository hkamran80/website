---
import { Author } from "../lib/structuredData";
import type { CollectionEntry } from "astro:content";

type Props = {
    post: CollectionEntry<"posts">;
};

const {
    post: { data: post },
} = Astro.props;
const url = new URL(Astro.url.pathname, Astro.site);

const updated = post.updated && post.updated !== "";

const structuredData =
    post.published && post.published !== ""
        ? {
              "@context": "https://schema.org",
              "@type": "Article",
              headline: post.title,
              description: post.description,
              datePublished: post.published.toISOString(),
              dateModified: updated
                  ? (post.updated as Date).toISOString()
                  : undefined,
              url: url.toString(),
              thumbnailUrl: post.img?.src ?? undefined,
              image: post.img
                  ? {
                        "@type": "ImageObject",
                        url: post.img.src,
                        width: 2000,
                        height: 1000,
                        caption: post.img.alt,
                    }
                  : undefined,
              author: Author,
              copyrightHolder: Author,
              copyrightYear: post.published.getFullYear(),
              copyrightNotice:
                  "Copyright © 2025 H. Kamran. All rights reserved.",
              inLanguage: "en-US",
              keywords: post.tags,
          }
        : {};
---

<script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(structuredData)}
/>

<link rel="canonical" href={url.toString()} />

<meta property="og:title" content={post.title} />
<meta property="og:type" content="article" />
<meta property="og:url" content={url.toString()} />
<meta name="description" content={post.description} />
<meta property="og:description" content={post.description} />

{post.img && <meta property="og:image" content={post.img.src} />}
{post.img && <meta property="og:image:alt" content={post.img.alt} />}
{post.img && <meta property="og:image:type" content="image/png" />}
{post.img && <meta property="og:image:width" content="2000" />}
{post.img && <meta property="og:image:height" content="1000" />}

<meta property="profile:first_name" content="H." />
<meta property="profile:last_name" content="Kamran" />
<meta property="profile:gender" content="male" />

{
    post.published && post.published !== "" && (
        <meta
            property="article:published_time"
            content={(post.published as Date).toISOString()}
        />
    )
}
{
    updated && (
        <meta
            property="article:modified_time"
            content={(post.updated as Date).toISOString()}
        />
    )
}

{post.tags.map((tag) => <meta property="article:tag" content={tag} />)}
