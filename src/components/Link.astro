---
import { EventNames } from "../navigation";

type Props = Pick<HTMLAnchorElement, "href"> &
    Partial<Omit<HTMLAnchorElement, "href" | "children">> & {
        class?: string;
        noAttribution?: boolean;
    };

const { href, class: className, noAttribution, ...props } = Astro.props;
let customAttributes = {
    ...props,
    rel: !("rel" in props) ? "noopener noreferrer" : props.rel,
};

let newHref = "";
let dataAttributes: Record<string, string> = { "data-umami-event": "" };

if (href.startsWith("/")) {
    newHref = href;
    dataAttributes["data-umami-event"] = EventNames.Local;
    dataAttributes["data-umami-event-url"] = href;
} else {
    if (href.includes("unsplash.com")) {
        dataAttributes["data-umami-event"] = EventNames.Social;
        dataAttributes["data-umami-event-platform"] = "Unsplash";
    } else {
        dataAttributes["data-umami-event"] = EventNames.Outbound;
        dataAttributes["data-umami-event-url"] = href;
    }

    if (!noAttribution)
        newHref = href + (href.includes("?") ? "&" : "?") + "ref=hkamran.com";
}
---

<>
    <a
        href={newHref}
        {...customAttributes}
        {...dataAttributes}
        class={className}
    >
        <slot />
    </a>
</>
