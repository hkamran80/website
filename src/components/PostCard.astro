---
import type { CollectionEntry } from "astro:content";

type Props = {
    post: CollectionEntry<"posts">;
};

const { post } = Astro.props;
---

<article class="space-y-1">
    <p class="p-name entry-title text-xl font-semibold">
        {post.data.title}
    </p>

    <p class="p-summary entry-summary text-c-light tracking-tight">
        {post.data.description}
    </p>

    <p class="text-c-lighter tracking-tight">
        {
            post.data.published && post.data.updated && (
                <time>
                    {new Intl.DateTimeFormat("en", {
                        year: "numeric",
                        month: "long",
                        day: "numeric",
                    }).formatRange(post.data.published, post.data.updated)}
                </time>
            )
        }

        {
            post.data.published ? (
                <time
                    datetime={post.data.published.toISOString()}
                    class={`dt-published published ${post.data.updated && "hidden"}`}
                >
                    {post.data.published.toLocaleDateString(undefined, {
                        year: "numeric",
                        month: "long",
                        day: "numeric",
                    })}
                </time>
            ) : (
                "Unpublished"
            )
        }

        {
            post.data.updated && (
                <time
                    datetime={post.data.updated.toISOString()}
                    class="dt-updated updated hidden"
                >
                    {post.data.updated.toLocaleDateString(undefined, {
                        year: "numeric",
                        month: "long",
                        day: "numeric",
                    })}
                </time>
            )
        }
    </p>
</article>
