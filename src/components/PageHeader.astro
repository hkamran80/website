---
type Props = {
    title: string;
    subtitle?: string;
    description?: string;
};

const { title, subtitle, description } = Astro.props;
---

<header class="flex flex-col space-y-2">
    <h1 class="text-3xl lg:text-4xl xl:text-5xl font-bold">
        {title}
    </h1>

    {
        (subtitle || Astro.slots.has("subtitle")) && (
            <p class="font-light leading-snug text-c-light">
                <slot name="subtitle">{subtitle}</slot>
            </p>
        )
    }

    {
        (description || Astro.slots.has("description")) && (
            <p class="font-light leading-snug text-c-light">
                <slot name="description">{description}</slot>
            </p>
        )
    }
</header>
