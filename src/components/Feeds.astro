---
import type { FeedTypes } from "../feeds.ts";

type Props = {
    feed: FeedTypes;
};
const { feed } = Astro.props;
---

<link
    rel="alternate"
    type="application/atom+xml"
    title={`Atom feed (${feed})`}
    href=`/feeds/${feed}.atom`
/>
<link
    rel="alternate"
    type="application/feed+json"
    title={`JSON feed (${feed})`}
    href=`/feeds/${feed}.json`
/>
