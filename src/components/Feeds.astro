---
type Props = {
    feed: "combined" | "articles" | "notes";
};
const { feed } = Astro.props;

const file = feed !== "combined" ? `feed-${feed}` : "feed";
---

<link
    rel="alternate"
    type="application/atom+xml"
    title={`Atom feed (${feed})`}
    href=`/${file}.atom`
/>
<link
    rel="alternate"
    type="application/rss+xml"
    title={`RSS feed (${feed})`}
    href=`/${file}.rss`
/>
<link
    rel="alternate"
    type="application/feed+json"
    title={`JSON feed (${feed})`}
    href=`/${file}.json`
/>
